    ["esp32:D12",   "btn_n:1.l", "green", []],

    ["esp32:GND.4", "btn_p:2.l", "black", []],
    ["esp32:D13",   "btn_p:1.l", "green", []],

    ["esp32:GND.5", "btn_k:2.l", "black", []],
    ["esp32:D14",   "btn_k:1.l", "green", []],

    ["esp32:GND.6", "rele:GND",  "black", []],
    ["esp32:3V3",   "rele:VCC",  "red",   []],
